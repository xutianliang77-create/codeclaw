{
  "name": "codeclaw",
  "version": "0.5.0",
  "description": "CLI-first personal autonomous agent platform scaffold",
  "type": "module",
  "private": true,
  "bin": {
    "codeclaw": "dist/cli.js"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test scripts eslint.config.js",
    "golden:ask": "tsx test/golden/runner/ask.ts",
    "setup:lsp": "bash ./scripts/setup-lsp.sh",
    "build": "bun run scripts/build.mjs",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "better-sqlite3": "^11.10.0",
    "ink": "^5.2.1",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-devtools-core": "latest",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.21",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "esbuild": "^0.25.4",
    "eslint": "^9.26.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.1",
    "vitest": "^3.1.2"
  }
}
